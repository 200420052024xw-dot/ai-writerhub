# Copy this file to backend/.env and fill in your settings.

# AI 模型配置
AI_PROVIDER=deepseek-ai/DeepSeek-V4-Flash
AI_API_KEY=your-api-key
AI_BASE_URL=https://api.siliconflow.cn/v1
AI_DEFAULT_MODEL=deepseek-ai/DeepSeek-V4-Flash
AI_TIMEOUT_SECONDS=60

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=writerhub

# CORS — 逗号分隔的允许来源（部署时改为实际域名）
# 开发环境默认值：http://127.0.0.1:5173,http://localhost:5173
CORS_ORIGINS=https://your-domain.com

# 前端静态文件目录（部署时设为前端 build 输出的绝对路径）
# 例如：/opt/writerhub/frontend/dist
# 留空则不启用静态文件服务（开发模式）
STATIC_DIR=

# RAG 配置
RAG_EMBEDDING_SOURCE=api
RAG_LOCAL_MODEL_PATH=
RAG_API_KEY=your-api-key
RAG_BASE_URL=https://api.siliconflow.cn/v1
RAG_RECALL_STRATEGY=hybrid
RAG_ENABLE_RERANK=false
RAG_RERANK_MODEL_PATH=
